{
  "version": "1.0",
  "jobId": "example-ecommerce-scraper",
  "startUrl": "https://example-shop.com/products?page=1",
  "pagination": {
    "enabled": true,
    "type": "queryParam",
    "param": "page",
    "maxPages": 10,
    "delayMs": 2000
  },
  "infiniteScroll": {
    "enabled": false,
    "maxScrolls": 20,
    "delayMs": 3000
  },
  "listing": {
    "itemSelector": ".product-card",
    "fields": [
      {
        "name": "title",
        "selector": ".product-title",
        "attr": "text",
        "type": "string",
        "required": true
      },
      {
        "name": "price",
        "selector": ".product-price",
        "attr": "text",
        "type": "string"
      },
      {
        "name": "url",
        "selector": "a.product-link",
        "attr": "href",
        "type": "url",
        "required": true
      },
      {
        "name": "image",
        "selector": "img.product-image",
        "attr": "src",
        "type": "url"
      },
      {
        "name": "rating",
        "selector": ".rating-value",
        "attr": "text",
        "type": "string"
      },
      {
        "name": "category",
        "selector": ".product-category",
        "attr": "text",
        "type": "string"
      }
    ]
  },
  "export": {
    "format": "csv",
    "filename": "products-export.csv",
    "includeUtf8Bom": true
  },
  "limits": {
    "maxItems": 1000
  }
}
