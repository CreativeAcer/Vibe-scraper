{
  "version": "1.0",
  "jobId": "example-ecommerce-scraper",
  "startUrl": "https://example-shop.com/products?page=1",
  "auth": {
    "mode": "sessionReuse"
  },
  "pagination": {
    "type": "queryParam",
    "param": "page",
    "start": 1,
    "maxPages": 10,
    "delayMs": {
      "min": 1500,
      "max": 3000
    },
    "stopOnNoNewItems": true
  },
  "infiniteScroll": {
    "enabled": false,
    "maxScrolls": 20,
    "delayMs": {
      "min": 1000,
      "max": 2000
    }
  },
  "listing": {
    "itemSelector": ".product-card",
    "fields": [
      {
        "name": "title",
        "selector": ".product-title",
        "attr": "text",
        "type": "string",
        "required": true
      },
      {
        "name": "price",
        "selector": ".product-price",
        "attr": "text",
        "type": "number",
        "transform": {
          "remove": ["€", ",", " "]
        }
      },
      {
        "name": "original_price",
        "selector": ".original-price",
        "attr": "text",
        "type": "number",
        "transform": {
          "remove": ["€", ",", " "]
        }
      },
      {
        "name": "url",
        "selector": "a.product-link",
        "attr": "href",
        "type": "url",
        "required": true
      },
      {
        "name": "image",
        "selector": "img.product-image",
        "attr": "src",
        "type": "url"
      },
      {
        "name": "rating",
        "selector": ".rating-value",
        "attr": "text",
        "type": "number"
      },
      {
        "name": "in_stock",
        "selector": ".stock-indicator",
        "attr": "text",
        "type": "boolean"
      },
      {
        "name": "category",
        "selector": ".product-category",
        "attr": "text",
        "type": "string"
      }
    ],
    "detail": {
      "followLink": {
        "selector": "a.product-link",
        "attr": "href"
      },
      "fields": [
        {
          "name": "sku",
          "selector": ".product-sku",
          "attr": "text",
          "type": "string"
        },
        {
          "name": "description",
          "selector": ".product-description",
          "attr": "html",
          "type": "string"
        },
        {
          "name": "specifications",
          "selector": ".specs-table",
          "attr": "html",
          "type": "string"
        },
        {
          "name": "reviews_count",
          "selector": ".reviews-count",
          "attr": "text",
          "type": "number"
        }
      ]
    },
    "dedupe": {
      "keys": ["url", "sku"]
    }
  },
  "delays": {
    "perActionMs": {
      "min": 500,
      "max": 1500
    }
  },
  "export": {
    "format": "csv",
    "filename": "products-export.csv",
    "bom": true
  },
  "limits": {
    "maxItems": 1000
  },
  "compliance": {
    "requireUserConsentPerHost": true
  }
}
